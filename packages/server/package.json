{
  "name": "@sweefi/server",
  "version": "0.1.0",
  "type": "module",
  "description": "s402 server middleware (chain-agnostic) and Sui client fetch wrapper for Hono and Node.js",
  "keywords": ["s402", "http-402", "payment", "web3", "ai-agent", "micropayments", "hono"],
  "homepage": "https://github.com/sweeinc/sweefi#readme",
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client/index.d.mts",
        "default": "./dist/client/index.mjs"
      },
      "require": {
        "types": "./dist/client/index.d.cts",
        "default": "./dist/client/index.cjs"
      },
      "default": "./dist/client/index.mjs"
    },
    "./server": {
      "import": {
        "types": "./dist/server/index.d.mts",
        "default": "./dist/server/index.mjs"
      },
      "require": {
        "types": "./dist/server/index.d.cts",
        "default": "./dist/server/index.cjs"
      },
      "default": "./dist/server/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/sweefi.git",
    "directory": "packages/server"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "s402": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "hono": "^4.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  },
  "peerDependencies": {
    "hono": ">=4.0.0"
  }
}
