{
  "name": "@sweepay/facilitator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Self-hostable payment verification and settlement service for SweePay",
  "license": "MIT",
  "author": "Danny Devs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Danny-Devs/sweepay.git",
    "directory": "packages/facilitator"
  },
  "main": "./dist/index.mjs",
  "files": ["dist", "Dockerfile", "fly.toml", "README.md", "LICENSE"],
  "scripts": {
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "dev": "tsx --env-file=.env src/index.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.8.0",
    "@mysten/sui": "^2.0.0",
    "s402": "^0.1.0",
    "@sweepay/core": "workspace:*",
    "@sweepay/sui": "workspace:*",
    "hono": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsdown": "^0.20.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
