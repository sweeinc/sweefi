{
  "name": "@sweepay/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for AI agent payments on Sui — the bridge between OpenClaw skills and the SweePay protocol",
  "license": "MIT",
  "author": "Danny Devs",
  "bin": {
    "sweepay": "./dist/index.mjs",
    "swee": "./dist/index.mjs",
    "sp": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@sweepay/core": "workspace:*",
    "@sweepay/sui": "workspace:*",
    "@sweepay/sdk": "workspace:*",
    "@mysten/sui": "^2.0.0"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
