{
  "name": "@sweefi/cli",
  "version": "0.1.0",
  "type": "module",
  "description": "CLI for AI agent payments on Sui — pay, stream, escrow, and manage mandates from the terminal",
  "keywords": [
    "sui",
    "s402",
    "http-402",
    "payment",
    "web3",
    "ai-agent",
    "defi",
    "micropayments",
    "agentic-commerce",
    "cli"
  ],
  "homepage": "https://sweefi.xyz",
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "bin": {
    "sweefi": "./dist/index.mjs",
    "swee": "./dist/index.mjs",
    "sf": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "dependencies": {
    "@mysten/sui": "^2.6.0",
    "@sweefi/sui": "workspace:^",
    "s402": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
