{
  "name": "@sweefi/sui",
  "version": "0.2.4",
  "type": "module",
  "description": "Sui-native s402 protocol implementation for SweeFi",
  "keywords": [
    "sui",
    "s402",
    "http-402",
    "payment",
    "web3",
    "ai-agent",
    "defi",
    "micropayments",
    "agentic-commerce"
  ],
  "homepage": "https://sweefi.xyz",
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./ptb": {
      "import": {
        "types": "./dist/ptb/index.d.mts",
        "default": "./dist/ptb/index.mjs"
      },
      "require": {
        "types": "./dist/ptb/index.d.cts",
        "default": "./dist/ptb/index.cjs"
      },
      "default": "./dist/ptb/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "demo": "tsx examples/demo.ts",
    "test": "SKIP_DRYRUN=1 vitest run",
    "test:offline": "SKIP_DRYRUN=1 vitest run",
    "test:live": "SWEEFI_LIVE_TESTNET=1 vitest run test/integration/dryrun.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/sweefi.git",
    "directory": "packages/sui"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sweefi/server": "workspace:^",
    "@sweefi/ui-core": "workspace:^",
    "s402": "^0.2.0"
  },
  "bugs": {
    "url": "https://github.com/sweeinc/sweefi/issues"
  },
  "peerDependencies": {
    "@mysten/sui": "^2.0.0"
  },
  "devDependencies": {
    "@mysten/sui": "^2.6.0",
    "@sweefi/server": "workspace:^",
    "@types/node": "^22.0.0",
    "tsdown": "^0.20.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
