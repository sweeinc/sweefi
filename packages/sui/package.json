{
  "name": "@sweepay/sui",
  "version": "0.1.0",
  "type": "module",
  "description": "Sui-native s402 protocol implementation for SweePay",
  "license": "MIT",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "default": "./dist/index.mjs"
    },
    "./ptb": {
      "import": {
        "types": "./dist/ptb/index.d.mts",
        "default": "./dist/ptb/index.mjs"
      },
      "require": {
        "types": "./dist/ptb/index.d.cts",
        "default": "./dist/ptb/index.cjs"
      },
      "default": "./dist/ptb/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "demo": "tsx examples/demo.ts",
    "test": "SKIP_DRYRUN=1 vitest run",
    "test:offline": "SKIP_DRYRUN=1 vitest run",
    "test:live": "SWEEPAY_LIVE_TESTNET=1 vitest run test/integration/dryrun.test.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "files": ["dist/**/*.mjs", "dist/**/*.cjs", "dist/**/*.d.mts", "dist/**/*.d.cts", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Danny-Devs/sweepay.git",
    "directory": "packages/sui"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "s402": "^0.1.0",
    "@sweepay/core": "workspace:*"
  },
  "peerDependencies": {
    "@mysten/sui": "^1.20.0"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
