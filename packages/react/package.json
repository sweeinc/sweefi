{
  "name": "@sweefi/react",
  "version": "0.1.0",
  "type": "module",
  "description": "React hooks and context for the SweeFi s402 payment flow",
  "keywords": ["s402", "http-402", "payment", "web3", "react", "ai-agent", "micropayments"],
  "homepage": "https://github.com/sweeinc/sweefi#readme",
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/sweefi.git",
    "directory": "packages/react"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sweefi/ui-core": "workspace:*",
    "s402": "^0.1.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/react": "^19.1.10",
    "jsdom": "^24.1.0",
    "react": "^19.1.1",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  }
}
