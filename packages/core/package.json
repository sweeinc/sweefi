{
  "name": "@sweepay/core",
  "version": "0.1.0",
  "type": "module",
  "description": "Shared types, client factories, error hierarchy for SweePay",
  "license": "MIT",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "default": "./dist/index.mjs"
    },
    "./s402": {
      "import": {
        "types": "./dist/s402/index.d.mts",
        "default": "./dist/s402/index.mjs"
      },
      "default": "./dist/s402/index.mjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck && npm run test"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "https://github.com/Danny-Devs/sweepay.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@mysten/seal": "^0.2.0",
    "@mysten/walrus": "^1.0.0",
    "s402": "^0.1.0"
  },
  "peerDependencies": {
    "@mysten/sui": "^1.20.0"
  },
  "devDependencies": {
    "tsdown": "^0.20.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.5"
  }
}
