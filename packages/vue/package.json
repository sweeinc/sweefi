{
  "name": "@sweefi/vue",
  "version": "0.1.0",
  "type": "module",
  "description": "Vue 3 composables and plugin for the SweeFi s402 payment flow",
  "keywords": [
    "sui",
    "s402",
    "http-402",
    "payment",
    "web3",
    "ai-agent",
    "defi",
    "micropayments",
    "agentic-commerce",
    "vue"
  ],
  "homepage": "https://sweefi.xyz",
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/sweefi.git",
    "directory": "packages/vue"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sweefi/ui-core": "workspace:^",
    "s402": "^0.2.0"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vue/test-utils": "^2.4.6",
    "jsdom": "^24.1.0",
    "tsdown": "^0.20.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5",
    "vue": "^3.5.13"
  }
}
