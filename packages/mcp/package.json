{
  "name": "@sweefi/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server exposing SweeFi payment tools for AI agents — the safety layer for autonomous agent commerce",
  "license": "Apache-2.0",
  "author": "Danny Devs",
  "repository": {
    "type": "git",
    "url": "https://github.com/sweeinc/sweefi.git",
    "directory": "packages/mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sui",
    "payments",
    "ai-agent",
    "streaming-payments",
    "escrow",
    "web3"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "bin": {
    "sweefi-mcp": "./dist/cli.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/cli.mjs",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck && pnpm run test"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sweefi/sdk": "workspace:*",
    "@sweefi/sui": "workspace:*",
    "zod": "^3.22.0"
  },
  "peerDependencies": {
    "@mysten/sui": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsdown": "^0.20.3",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
