{
  "name": "@sweepay/mcp",
  "version": "0.1.0",
  "type": "module",
  "description": "MCP server exposing SweePay payment tools for AI agents — the safety layer for autonomous agent commerce",
  "license": "MIT",
  "author": "Danny Devs",
  "bin": {
    "sweepay-mcp": "./dist/index.mjs"
  },
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "scripts": {
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@sweepay/core": "workspace:*",
    "@sweepay/sui": "workspace:*",
    "@mysten/sui": "^1.20.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "tsdown": "^0.20.3",
    "tsx": "^4.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.2.6",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.0.5"
  }
}
