# Agent wallet — funded Sui testnet keypair (bech32 suiprivkey1... or base64)
# Get testnet SUI: https://faucet.sui.io
SUI_PRIVATE_KEY=

# Merchant wallet — receives payments (Sui address, 0x + 64 hex chars)
# REQUIRED: Use your own testnet address to verify settlement on-chain
MERCHANT_ADDRESS=

# Facilitator API key — must be >= 16 characters
# Generate: openssl rand -hex 32
FACILITATOR_API_KEY=demo-facilitator-key-0123456789abcdef

# Optional: facilitator fee recipient address
FEE_RECIPIENT=

# SweeFi package ID on testnet (for event anti-spoofing in facilitator)
SWEEFI_PACKAGE_ID=
