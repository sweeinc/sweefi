# s402 Agent Demo — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to git. NEVER paste private keys on the command line.

# Your Sui testnet private key (bech32 suiprivkey1... format)
# To export from Sui CLI:
#   sui keytool export --key-identity <alias> --json | jq -r '.exportedPrivateKey'
#   → outputs bech32: suiprivkey1qg5...
#
# Or generate a new one:
#   sui keytool generate ed25519
SUI_PRIVATE_KEY=

# Optional: override the API server URL (default: http://localhost:3402)
# API_BASE=http://localhost:3402
